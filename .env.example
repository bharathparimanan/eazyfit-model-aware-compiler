# LLM providers (use at least one)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# LlamaParse (https://cloud.llamaindex.ai)
LLAMA_CLOUD_API_KEY=

# LangSmith observability (https://smith.langchain.com)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=eazyfit-compiler
LANGCHAIN_TRACING_V2=true

# File handling
FILE_DIRECTORY=./storage
FILE_UPLOAD_PERMISSIONS=rw
FILE_UPLOAD_FOLDER=uploads
FILE_PARSE_PERMISSIONS=r
FILE_PARSE_FOLDER=parsed

# Semantic cache
CACHE_SIMILARITY_THRESHOLD=0.85
CACHE_BACKEND=sqlite
CACHE_VECTOR_BACKEND=faiss
